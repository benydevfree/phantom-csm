{
  "title": "phantom-csm",
  "uid": "phantom-csm",
  "schemaVersion": 38,
  "version": 1,
  "refresh": "30s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Requêtes / min",
      "gridPos": { "x": 0, "y": 0, "w": 6, "h": 4 },
      "datasource": { "uid": "prometheus" },
      "targets": [{
        "expr": "rate(http_requests_total{service=\"phantom-csm\"}[1m]) * 60",
        "legendFormat": "req/min"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "reqpm", "color": { "mode": "thresholds" }, "thresholds": { "steps": [
        { "color": "green", "value": null },
        { "color": "orange", "value": 100 },
        { "color": "red", "value": 500 }
      ]}}}
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Taux d'erreur 5xx",
      "gridPos": { "x": 6, "y": 0, "w": 6, "h": 4 },
      "datasource": { "uid": "prometheus" },
      "targets": [{
        "expr": "sum(rate(http_requests_total{service=\"phantom-csm\",status=~\"5..\"}[5m])) / sum(rate(http_requests_total{service=\"phantom-csm\"}[5m])) * 100",
        "legendFormat": "% erreurs"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "percent", "color": { "mode": "thresholds" }, "thresholds": { "steps": [
        { "color": "green", "value": null },
        { "color": "orange", "value": 1 },
        { "color": "red", "value": 5 }
      ]}}}
    },
    {
      "id": 3,
      "type": "stat",
      "title": "P95 latence",
      "gridPos": { "x": 12, "y": 0, "w": 6, "h": 4 },
      "datasource": { "uid": "prometheus" },
      "targets": [{
        "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_ms_bucket{service=\"phantom-csm\"}[5m])) by (le))",
        "legendFormat": "p95 ms"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" },
      "fieldConfig": { "defaults": { "unit": "ms", "color": { "mode": "thresholds" }, "thresholds": { "steps": [
        { "color": "green", "value": null },
        { "color": "orange", "value": 500 },
        { "color": "red", "value": 2000 }
      ]}}}
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Scrape jobs traités",
      "gridPos": { "x": 18, "y": 0, "w": 6, "h": 4 },
      "datasource": { "uid": "prometheus" },
      "targets": [{
        "expr": "increase(scrape_jobs_total{service=\"phantom-csm\"}[24h])",
        "legendFormat": "jobs/24h"
      }],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "value" },
      "fieldConfig": { "defaults": { "unit": "short" } }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Requêtes HTTP par status",
      "gridPos": { "x": 0, "y": 4, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(http_requests_total{service=\"phantom-csm\"}[1m])) by (status)",
          "legendFormat": "{{status}}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Latence HTTP (p50 / p95 / p99)",
      "gridPos": { "x": 12, "y": 4, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_request_duration_ms_bucket{service=\"phantom-csm\"}[5m])) by (le))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_ms_bucket{service=\"phantom-csm\"}[5m])) by (le))",
          "legendFormat": "p95"
        },
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_request_duration_ms_bucket{service=\"phantom-csm\"}[5m])) by (le))",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Scrape jobs — succès vs erreurs",
      "gridPos": { "x": 0, "y": 12, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(scrape_jobs_total{service=\"phantom-csm\",status=\"success\"}[5m]))",
          "legendFormat": "succès"
        },
        {
          "expr": "sum(rate(scrape_jobs_total{service=\"phantom-csm\",status=\"error\"}[5m]))",
          "legendFormat": "erreurs"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "ops", "custom": { "lineWidth": 2 } } }
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Sessions actives",
      "gridPos": { "x": 12, "y": 12, "w": 12, "h": 8 },
      "datasource": { "uid": "prometheus" },
      "targets": [{
        "expr": "active_sessions{service=\"phantom-csm\"}",
        "legendFormat": "sessions"
      }],
      "fieldConfig": { "defaults": { "unit": "short", "custom": { "lineWidth": 2 } } }
    }
  ]
}
